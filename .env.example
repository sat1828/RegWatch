# RegWatch Configuration

# App
ENVIRONMENT=development
DEBUG=true
API_KEY=regwatch-dev-key-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://regwatch:regwatch@localhost:5432/regwatch
DATABASE_SYNC_URL=postgresql://regwatch:regwatch@localhost:5432/regwatch

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (optional - mock fallback when not set)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Pinecone (optional - disabled when not set)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=regwatch

# Notifications (optional - disabled when not set)
RESEND_API_KEY=
SLACK_WEBHOOK_URL=
NOTIFICATION_EMAIL_FROM=regwatch@example.com

# Scraper
PLAYWRIGHT_HEADLESS=true
SCRAPYD_TIMEOUT_SECONDS=30
MAX_CONCURRENT_SCRAPES=5

# Scheduler (production only)
SCHEDULER_WATCHER_INTERVAL_HOURS=24
SCHEDULER_FULL_PIPELINE_INTERVAL_HOURS=168

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=
